<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/surface_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical">

        <!-- أيقونة الصلاة (هنضيفها بعدين) -->
        <ImageView
            android:id="@+id/prayerIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_mosque"
            android:contentDescription="أيقونة الصلاة"
            app:tint="@color/purple_500" />

        <!-- اسم الصلاة -->
        <TextView
            android:id="@+id/prayerName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="الفجر"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- وقت الصلاة -->
        <TextView
            android:id="@+id/prayerTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="04:10 ص"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/purple_700" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>

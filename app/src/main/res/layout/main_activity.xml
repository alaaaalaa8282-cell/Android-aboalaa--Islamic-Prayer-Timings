                    android:textAlignment="viewStart"
                    android:textSize="28sp" />

                <TextView
                    android:id="@+id/maghrib"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="viewEnd"
                    android:textSize="28sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
